{% comment %}
  Unified skills entry renderer for both formats
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="skill-item">
      {% if entry.icon %}
        <i class="{{ entry.icon }}"></i>
      {% endif %}
      <strong>
        {% capture skill_name %}
          {% if entry.label %}{{ entry.label }}{% elsif entry.name %}{{ entry.name }}{% endif %}
        {% endcapture %}
        {{- skill_name -}}
        {%- if entry.level %} ({{ entry.level }}){% endif %}:</strong
      >
      
      {% capture skill_details %}
        {% if entry.details %}{{ entry.details }}{% elsif entry.keywords %}{{ entry.keywords }}{% endif %}
      {% endcapture %}

      {% if skill_details %}
        {% for keyword in skill_details %}
          {% if forloop.last %}
            {{ keyword }}
          {% else %}
            {{ keyword }},
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .skill-item {
    padding: 0.5rem 0;
  }
</style>
